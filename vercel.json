{"$schema": "https://openapi.vercel.sh/vercel.json", "framework": "vite", "buildCommand": "npm run build", "outputDirectory": "dist", "headers": [{"source": "/(.*).html", "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]}, {"source": "/assets/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]}, {"source": "/(.*)", "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]}], "rewrites": [{"source": "/api/:path*", "destination": "https://gaokao-zhiyuan-app-production.up.railway.app/api/:path*"}, {"source": "/health", "destination": "https://gaokao-zhiyuan-app-production.up.railway.app/health"}]}