{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gaokao-zhiyuan-app-production.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://gaokao-zhiyuan-app-production.up.railway.app/health"
    }
  ]
}
