# ===== 生产环境变量模板 =====
# 复制本文件为 .env.prod 并填入真实值，切勿把真实密钥提交到代码仓库。

# 服务端口（容器内固定 8080，由 nginx 对外暴露 80）
PORT=8080

# CORS 白名单：生产环境务必填真实前端域名，不要用 *
CORS_ORIGIN=https://your-domain.com

# 云数据库 PostgreSQL 连接串（TencentDB for PostgreSQL，上海 ap-shanghai）
# 格式：postgresql://<用户名>:<密码>@<内网地址>:<端口>/<库名>
# 上海地域内网地址形如：sh-xxxxxx.pg.ap-shanghai.tencentcloud.com（以控制台为准）
DATABASE_URL=postgresql://gaokao:YourStrongPassword@sh-xxxxxx.pg.ap-shanghai.tencentcloud.com:5432/gaokao_db

# 部署地域（仅作记录，便于后续切 CLB/多可用区时核对）
TENCENT_REGION=ap-shanghai

# ===== DeepSeek 大模型配置 =====
# 强烈建议通过腾讯云「密钥管理」或服务器环境变量注入，不要硬编码进镜像/仓库
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_TIMEOUT=60000

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_CONSOLE=true
LOG_FLUSH_INTERVAL_MS=3000
LOG_DIR=/app/logs
