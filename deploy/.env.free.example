# ============================================================
# 免费平台环境变量模板（Supabase + DeepSeek）
# 复制为 backend/.env 或直接在 Render 控制台填入，切勿提交到仓库
# ============================================================

# —— 数据库：Supabase 免费 PostgreSQL 连接串 ——
# 格式：postgresql://postgres:<密码>@db.<项目ID>.supabase.co:5432/postgres
# 在 Supabase 控制台 → Project Settings → Database → Connection string 获取
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# —— 大模型：DeepSeek 密钥（务必保密）——
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_TIMEOUT=60000

# —— 服务 ——
PORT=8080
NODE_ENV=production
